import express from 'express';
import session from 'express-session';
import path from 'path';
import { fileURLToPath } from 'url';
import { validarDatos } from './middlewares/validarDatos.js';
import { autenticarUsuario } from './middlewares/autenticarUsuario.js';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const app = express();
const PORT = 3000;

// Middleware para leer body
app.use(express.urlencoded({ extended: true }));

// Configurar sesión
app.use(session({
  secret: 'claveSecreta',
  resave: false,
  saveUninitialized: true
}));

// Servir login.html
app.get('/', (req, res) => {
  res.sendFile(path.join(__dirname, 'views', 'login.html'));
});

// Ruta de login con middlewares
app.post('/login', validarDatos, autenticarUsuario, (req, res) => {
  req.session.user = req.user.email;
  res.redirect('/perfil');
});

// Middleware de protección de rutas
function protegerRuta(req, res, next) {
  if (!req.session.user) {
    return res.redirect('/');
  }
  next();
}

// Página protegida
app.get('/perfil', protegerRuta, (req, res) => {
  res.send(` Bienvenido ${req.session.user}`);
});

// Logout
app.get('/logout', (req, res) => {
  req.session.destroy(() => res.redirect('/'));
});

// Iniciar servidor
app.listen(PORT, () => console.log(`Servidor corriendo en http://localhost:${PORT}`));
